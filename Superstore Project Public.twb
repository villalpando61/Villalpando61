    <worksheet name='Product to stop selling'>
      <table>
        <view>
          <datasources>
            <datasource caption='Orders+ (Superstore)' name='federated.06cp70m0oubayp13x0wtv0lp5mbz' />
          </datasources>
          <datasource-dependencies datasource='federated.06cp70m0oubayp13x0wtv0lp5mbz'>
            <column datatype='string' name='[Product Name]' role='dimension' type='nominal' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column-instance column='[Product Name]' derivation='None' name='[none:Product Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Profit]' derivation='Sum' name='[sum:Profit:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.06cp70m0oubayp13x0wtv0lp5mbz].[none:Product Name:nk]'>
            <groupfilter count='20' end='bottom' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='SUM([Profit])' function='order' user:ui-marker='order'>
                <groupfilter function='level-members' level='[none:Product Name:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
              </groupfilter>
            </groupfilter>
          </filter>
          <computed-sort column='[federated.06cp70m0oubayp13x0wtv0lp5mbz].[none:Product Name:nk]' direction='ASC' using='[federated.06cp70m0oubayp13x0wtv0lp5mbz].[sum:Profit:qk]' />
          <slices>
            <column>[federated.06cp70m0oubayp13x0wtv0lp5mbz].[none:Product Name:nk]</column>
          </slices>
          <aggregation value='true' />
